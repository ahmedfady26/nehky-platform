// =================================================================
// نماذج إضافية للمنشورات - Posts Additional Models
// =================================================================

// نموذج المشاركات (Share) - لتتبع مشاركة المنشورات
model Share {
  id     String @id @default(cuid()) // معرف المشاركة
  userId String // معرف المستخدم الذي شارك
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId String // معرف المنشور المشارك
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  // معلومات المشاركة
  shareType String  @default("REPOST") // REPOST, SHARE_LINK, QUOTE
  comment   String? // تعليق على المشاركة

  // معلومات تقنية
  ipAddress String? // عنوان IP
  platform  String? // المنصة المشارك عليها

  createdAt DateTime @default(now())

  @@unique([userId, postId]) // منع المشاركة المكررة
  @@index([postId])
  @@index([userId])
  @@map("shares")
}

// نموذج مشاهدات المنشورات (PostView) - لتتبع المشاهدات
model PostView {
  id     String  @id @default(cuid()) // معرف المشاهدة
  userId String? // معرف المستخدم (null للزوار)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  postId String // معرف المنشور
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)

  // معلومات المشاهدة
  duration Int? // مدة المشاهدة بالثواني
  viewType String @default("VIEW") // VIEW, CLICK, IMPRESSION

  // معلومات تقنية
  ipAddress String? // عنوان IP
  userAgent String? // معلومات المتصفح
  referer   String? // المصدر

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@map("post_views")
}

// نموذج تسجيل تكرارات الكلمات (KeywordOccurrence) - لتتبع مصدر كل كلمة شائعة بدقة
model KeywordOccurrence {
  id String @id @default(cuid()) // معرف التكرار الفريد

  // الكلمة والمعلومات الأساسية
  keyword           String // الكلمة/هاشتاج/منشن كما ظهرت
  normalizedKeyword String // الكلمة منظفة (lowercase, no symbols)
  type              String // HASHTAG, KEYWORD, MENTION
  position          Int? // موقع الكلمة في النص (أول حرف)
  context           String? // السياق المحيط بالكلمة (50 حرف قبل وبعد)

  // العلاقات مع الكيانات الأخرى
  postId String // معرف المنشور الذي تحتوي على الكلمة
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  userId String // معرف المستخدم (مؤلف المنشور)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trendingKeywordId String? // ربط مع جدول الكلمات الشائعة (اختياري)
  trendingKeyword   TrendingKeyword? @relation(fields: [trendingKeywordId], references: [id], onDelete: SetNull)

  // ربط مع الإداري الذي سجل أو راجع هذا التكرار (اختياري)
  recordedByAdminId String? // معرف الإداري الذي سجل أو راجع التكرار يدوياً
  recordedByAdmin   Admin?  @relation("AdminRecordedOccurrences", fields: [recordedByAdminId], references: [id], onDelete: SetNull)

  // معلومات إضافية للتحليل
  sentiment String? @default("NEUTRAL") // POSITIVE, NEGATIVE, NEUTRAL
  language  String  @default("AR") // AR, EN, MIXED
  category  String? // تصنيف الكلمة (تقنية، رياضة، ثقافة)

  // معلومات السياق والتفاعل
  postStatus      String? // حالة المنشور وقت التسجيل
  postVisibility  String? // رؤية المنشور (PUBLIC, PRIVATE, etc.)
  authorRole      String? // دور المؤلف (USER, INFLUENCER, TOP_FOLLOWER)
  authorVerified  Boolean? @default(false) // هل المؤلف موثق
  authorFollowers Int?     @default(0) // عدد متابعي المؤلف وقت النشر

  // معلومات تقنية
  extractedBy String  @default("SYSTEM") // مصدر الاستخراج (SYSTEM, MANUAL, API)
  ipAddress   String? // عنوان IP للمستخدم
  userAgent   String? // معلومات المتصفح

  // توقيت التكرار
  occurredAt DateTime @default(now()) // وقت تسجيل الكلمة (عادة = وقت إنشاء المنشور)
  createdAt  DateTime @default(now()) // وقت إضافة السجل للنظام

  // معلومات إضافية للتحليل المتقدم
  isOriginalPost  Boolean @default(true) // هل هو منشور أصلي أم مشاركة
  interactionData String? // بيانات التفاعل كـ JSON (likes, shares, etc.)
  geolocation     String? // الموقع الجغرافي (إذا متاح)

  @@index([keyword]) // فهرس الكلمة للبحث السريع
  @@index([normalizedKeyword]) // فهرس الكلمة المنظفة
  @@index([postId]) // فهرس المنشور
  @@index([userId]) // فهرس المستخدم
  @@index([trendingKeywordId]) // فهرس الكلمة الشائعة
  @@index([recordedByAdminId]) // فهرس الإداري المسجل
  @@index([type]) // فهرس نوع الكلمة
  @@index([occurredAt]) // فهرس وقت التكرار
  @@index([createdAt]) // فهرس وقت الإنشاء
  @@index([keyword, postId]) // فهرس مركب للبحث المتقدم
  @@index([normalizedKeyword, type]) // فهرس مركب للتحليل
  @@index([userId, occurredAt]) // فهرس مركب لتحليل المستخدم
  @@index([recordedByAdminId, occurredAt]) // فهرس مركب للأنشطة الإدارية
  @@map("keyword_occurrences")
}

// نموذج الإداريين (Admin) - لتتبع الأنشطة الإدارية
model Admin {
  id     String @id @default(cuid()) // معرف الإداري الفريد
  userId String @unique // ربط مع جدول المستخدمين
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // معلومات الصلاحيات الإدارية
  role        String  @default("ADMIN") // ADMIN, SUPER_ADMIN, MODERATOR
  permissions String? // JSON string للصلاحيات المحددة
  department  String? // القسم الإداري (content, users, keywords, system)

  // معلومات إضافية
  assignedBy   String? // من قام بتعيين هذا الإداري
  assignedAt   DateTime @default(now()) // تاريخ التعيين
  isActive     Boolean  @default(true) // هل الإداري نشط
  lastActiveAt DateTime @default(now()) // آخر نشاط إداري

  // ملاحظات ومعلومات إضافية
  notes       String? // ملاحظات حول الإداري
  accessLevel Int     @default(1) // مستوى الوصول (1-5)

  // العلاقات - الأنشطة التي قام بها الإداري
  recordedKeywordOccurrences KeywordOccurrence[] @relation("AdminRecordedOccurrences")
  trendReviews               TrendReviewLog[]    @relation("AdminTrendReviews")
  sentNotifications          AdminNotification[] @relation("AdminSentNotifications")

  @@index([userId]) // فهرس المستخدم
  @@index([role]) // فهرس الدور
  @@index([isActive]) // فهرس الحالة النشطة
  @@index([lastActiveAt]) // فهرس آخر نشاط
  @@map("admins")
}

// =================================================================
// الجداول الجديدة المطلوبة - New Required Tables
// =================================================================

// 1️⃣ جدول سجل مراجعة الترندات – trend_review_logs
model TrendReviewLog {
  id String @id @default(cuid()) // معرف السجل

  // العلاقات
  adminId String // معرف الأدمن
  admin   Admin  @relation("AdminTrendReviews", fields: [adminId], references: [id], onDelete: Cascade)

  keywordId String // الكلمة المعنية
  keyword   TrendingKeyword @relation("TrendReviews", fields: [keywordId], references: [id], onDelete: Cascade)

  // نوع الإجراء والتفاصيل
  actionTaken String // نوع الإجراء: BLOCK, PIN, POSTPONE, APPROVE, REJECT, EDIT
  notes       String? // ملاحظات اختيارية

  // معلومات إضافية عن الإجراء
  previousStatus String? // الحالة السابقة للكلمة
  newStatus      String? // الحالة الجديدة للكلمة
  reason         String? // سبب الإجراء
  duration       Int? // مدة الإجراء (بالساعات) إذا كان مؤقت

  // معلومات تقنية
  ipAddress String? // عنوان IP للإداري
  userAgent String? // معلومات المتصفح

  // التواريخ
  timestamp DateTime @default(now()) // وقت الإجراء
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId]) // فهرس الإداري
  @@index([keywordId]) // فهرس الكلمة
  @@index([actionTaken]) // فهرس نوع الإجراء
  @@index([timestamp]) // فهرس الوقت
  @@index([adminId, timestamp]) // فهرس مركب للأنشطة الإدارية
  @@map("trend_review_logs")
}

// 2️⃣ جدول معلومات الأجهزة – user_devices
model UserDevice {
  id String @id @default(cuid()) // معرف السجل

  // العلاقات
  userId String // المستخدم
  user   User   @relation("UserDevices", fields: [userId], references: [id], onDelete: Cascade)

  // معلومات الجهاز
  deviceType String // DESKTOP, MOBILE, TABLET
  os         String? // نظام التشغيل (Windows, macOS, iOS, Android, Linux)
  browser    String? // نوع المتصفح (Chrome, Safari, Firefox, Edge)
  
  // تفاصيل تقنية
  userAgent    String? // User-Agent الكامل
  screenWidth  Int? // عرض الشاشة
  screenHeight Int? // ارتفاع الشاشة
  language     String? // لغة المتصفح
  timezone     String? // المنطقة الزمنية

  // معلومات الشبكة والموقع
  ipAddress String? // عنوان IP
  country   String? // البلد
  city      String? // المدينة
  isp       String? // مزود الخدمة

  // معلومات إضافية
  isFirstTime Boolean @default(false) // هل هو أول تسجيل دخول من هذا الجهاز
  deviceName  String? // اسم الجهاز (إذا متوفر)
  
  // التواريخ
  loginTime  DateTime @default(now()) // وقت تسجيل الدخول
  lastUsedAt DateTime @default(now()) // آخر استخدام للجهاز
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId]) // فهرس المستخدم
  @@index([deviceType]) // فهرس نوع الجهاز
  @@index([os]) // فهرس نظام التشغيل
  @@index([browser]) // فهرس المتصفح
  @@index([loginTime]) // فهرس وقت الدخول
  @@index([userId, deviceType]) // فهرس مركب للتحليل
  @@index([country]) // فهرس البلد
  @@map("user_devices")
}

// 3️⃣ جدول رسائل الأدمن – admin_notifications
model AdminNotification {
  id String @id @default(cuid()) // معرف الرسالة

  // العلاقات
  adminId String // الأدمن المُرسل
  admin   Admin  @relation("AdminSentNotifications", fields: [adminId], references: [id], onDelete: Cascade)

  receiverUserId String // المستخدم المستقبل
  receiverUser   User   @relation("ReceivedAdminNotifications", fields: [receiverUserId], references: [id], onDelete: Cascade)

  // محتوى الرسالة
  title   String  // عنوان الرسالة
  message String  // نص الرسالة
  type    String  @default("INFO") // INFO, WARNING, SUCCESS, ERROR, ANNOUNCEMENT

  // معلومات إضافية
  priority    String @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  category    String? // تصنيف الرسالة (account, content, violation, system)
  actionUrl   String? // رابط إجراء مطلوب
  actionLabel String? // نص زر الإجراء

  // حالة الرسالة
  status     String   @default("SENT") // SENT, DELIVERED, READ, ARCHIVED
  isRead     Boolean  @default(false)
  readAt     DateTime?
  isArchived Boolean  @default(false)
  archivedAt DateTime?

  // معلومات تقنية
  ipAddress String? // عنوان IP للإداري المرسل
  userAgent String? // معلومات متصفح الإداري

  // التواريخ
  sentAt    DateTime @default(now()) // وقت الإرسال
  expiresAt DateTime? // تاريخ انتهاء الصلاحية (للإعلانات المؤقتة)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminId]) // فهرس الإداري المرسل
  @@index([receiverUserId]) // فهرس المستخدم المستقبل
  @@index([status]) // فهرس حالة الرسالة
  @@index([type]) // فهرس نوع الرسالة
  @@index([priority]) // فهرس الأولوية
  @@index([sentAt]) // فهرس وقت الإرسال
  @@index([isRead]) // فهرس حالة القراءة
  @@index([receiverUserId, isRead]) // فهرس مركب للرسائل غير المقروءة
  @@index([adminId, sentAt]) // فهرس مركب لأنشطة الإداري
  @@map("admin_notifications")
}
